# Unison API token (required). Get one at https://brain.unisonlabs.ai or via:
#   curl -X POST https://brain.unisonlabs.ai/v1/auth/provision \
#     -H 'Content-Type: application/json' \
#     -d '{"email":"you@example.com"}'
UNISON_TOKEN=usk_live_...

# Unison brain base URL (optional). Defaults to https://brain.unisonlabs.ai.
# Override to point at a self-hosted brain instance.
UNISON_API_URL=https://brain.unisonlabs.ai
